{
 "version": ,
 "builds": [
 {
 "src": "api/main.py",
 "use": "@vercel/python"
 },
 {
 "src": "frontend/package.json",
 "use": "@vercel/static-build",
 "config": {
 "distDir": "dist"
 }
 }
 ],
 "routes": [
 {
 "src": "/api/(.*)",
 "dest": "/api/main.py"
 },
 {
 "src": "/(.*)",
 "dest": "/frontend/dist/$"
 }
 ],
 "env": {
 "PYTHONPATH": "/var/task/backend"
 },
 "functions": {
 "api/main.py": {
 "maxDuration": 0
 }
 }
}